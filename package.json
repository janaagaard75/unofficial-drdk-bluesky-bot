{
  "name": "unofficial-drdk-bluesky-bot",
  "description": "Unofficial dr.dk news bot for Bluesky",
  "version": "0.0.0",
  "author": "Jan Aagaard <jan@aagaard.net>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "check-formatting": "prettier --check \"**/*.{css,html,js,json,md,scss,ts,tsx,yml}\"",
    "check-lint": "eslint --format unix --max-warnings 0",
    "check-types": "tsc",
    "check-unused": "yarn dlx --quiet ts-prune src/",
    "post-new-drdk-links": "tsx ./src/drdk/postNewDrdkLinks.ts",
    "post-new-hn-stories": "tsx ./src/hackerNews/postNewHnStories.ts",
    "test": "vitest",
    "test-drdk-description": "tsx --env-file=.env ./src/drdk/tests/testDescription.ts",
    "test-drdk-extract-article-text": "tsx --env-file=.env ./src/drdk/tests/testExtractArticleText.ts",
    "test-drdk-fetch-article": "tsx --env-file=.env ./src/drdk/tests/testFetchArticle.ts",
    "test-drdk-hero-images": "tsx --env-file=.env ./src/drdk/tests/testHeroImages.ts",
    "test-drdk-post-new-links": "tsx --env-file=.env ./src/drdk/tests/testPostNewLinks.ts",
    "test-drdk-post-test-links": "tsx --env-file=.env ./src/drdk/tests/testPostTestLinks.ts",
    "test-drdk-summarize": "tsx --env-file=.env ./src/drdk/tests/testSummarize.ts",
    "test-hn-404-image": "tsx --env-file=.env ./src/hackerNews/tests/testHnStory.ts 47032876",
    "test-hn-cookies": "tsx --env-file=.env ./src/hackerNews/tests/testHnStory.ts 47096520",
    "test-hn-get-new-story-ids": "tsx --env-file=.env ./src/hackerNews/tests/testGetNewHnStoryIds.ts",
    "test-hn-ids": "tsx --env-file=.env ./src/hackerNews/tests/testHnStoryIds.ts",
    "test-hn-paywall-comment": "tsx --env-file=.env ./src/hackerNews/tests/testHnStory.ts 46773791",
    "test-hn-paywall-description": "tsx --env-file=.env ./src/hackerNews/tests/testHnStory.ts 47489044",
    "test-hn-post-story": "tsx --env-file=.env ./src/hackerNews/tests/testPostingHnStory.ts",
    "test-hn-posted-story-ids": "tsx --env-file=.env ./src/hackerNews/tests/testPostedHnStoryIds.ts",
    "test-hn-story": "tsx --env-file=.env ./src/hackerNews/tests/testHnStory.ts",
    "update-dependencies": "yarn upgrade-interactive && rm yarn.lock && yarn install"
  },
  "dependencies": {
    "@atproto/api": "^0.19.6",
    "@mozilla/readability": "^0.6.0",
    "html-entities": "^2.6.0",
    "image-size": "^2.0.2",
    "jsdom": "^29.0.2",
    "openai": "^6.34.0",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-perfectionist": "^5.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.4"
  },
  "packageManager": "yarn@4.13.0"
}
